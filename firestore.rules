rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Nieuws: iedereen mag lezen, alleen de beheerder mag schrijven/wijzigen/verwijderen.
    match /news/{docId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email == 'bramvdelst@gmail.com'
                   && request.auth.token.email_verified == true;
    }

    // FCM tokens: client heeft geen directe toegang. Registratie loopt via
    // /api/register-token (Admin SDK), dat de rules omzeilt.
    match /fcm_tokens/{token} {
      allow read, write: if false;
    }
  }
}
